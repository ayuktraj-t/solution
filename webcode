<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Solution — Just type your problem, get a solution</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet"/>
<style>
:root {
  --ink: #0e0c1a;
  --ink2: #3a3650;
  --ink3: #7a7690;
  --bg: #f5f3ff;
  --bg2: #ede9ff;
  --white: #ffffff;
  --purple: #5b45e0;
  --purple-dark: #3d2db5;
  --purple-light: #ede9ff;
  --teal: #0d9e75;
  --teal-light: #e0f5ee;
  --coral: #e8401c;
  --coral-light: #fdeee9;
  --amber: #c97a10;
  --amber-light: #fdf2e0;
  --blue: #1a6fc4;
  --blue-light: #e5f0fb;
  --radius: 14px;
  --radius-sm: 8px;
  --radius-pill: 999px;
}

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

html { scroll-behavior: smooth; }

body {
  font-family: 'DM Sans', sans-serif;
  background: var(--bg);
  color: var(--ink);
  font-size: 16px;
  line-height: 1.6;
  min-height: 100vh;
}

h1, h2, h3, h4, h5 {
  font-family: 'Syne', sans-serif;
  line-height: 1.15;
}

/* ── Pages ── */
.page { display: none; }
.page.active { display: block; }

/* ── Nav ── */
nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(245,243,255,0.92);
  backdrop-filter: blur(12px);
  border-bottom: 1px solid rgba(91,69,224,0.1);
  padding: 0 40px;
  height: 64px;
  display: flex; align-items: center; justify-content: space-between;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: 'Syne', sans-serif;
  font-weight: 800; font-size: 20px; color: var(--purple);
  cursor: pointer; text-decoration: none;
}
.logo-mark {
  width: 34px; height: 34px; border-radius: 10px;
  background: var(--purple);
  display: flex; align-items: center; justify-content: center;
  color: white; font-size: 16px; font-weight: 800;
}
.nav-links { display: flex; gap: 6px; }
.nav-links a {
  font-size: 14px; font-weight: 500; color: var(--ink2);
  padding: 7px 14px; border-radius: var(--radius-sm);
  cursor: pointer; text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.nav-links a:hover { background: var(--bg2); color: var(--purple); }
.nav-cta {
  background: var(--purple); color: white;
  border: none; padding: 9px 22px;
  border-radius: var(--radius-sm);
  font-family: 'Syne', sans-serif;
  font-size: 14px; font-weight: 600;
  cursor: pointer; transition: background 0.15s, transform 0.1s;
}
.nav-cta:hover { background: var(--purple-dark); transform: translateY(-1px); }

/* ── Hero ── */
.hero {
  min-height: calc(100vh - 64px);
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  text-align: center;
  padding: 60px 24px 80px;
  position: relative; overflow: hidden;
}
.hero-orb {
  position: absolute; border-radius: 50%;
  pointer-events: none; animation: float 8s ease-in-out infinite;
}
.hero-orb1 {
  width: 500px; height: 500px;
  background: radial-gradient(circle, rgba(91,69,224,0.15) 0%, transparent 70%);
  top: -120px; right: -120px;
}
.hero-orb2 {
  width: 400px; height: 400px;
  background: radial-gradient(circle, rgba(13,158,117,0.12) 0%, transparent 70%);
  bottom: -100px; left: -80px;
  animation-delay: -4s;
}
@keyframes float {
  0%, 100% { transform: translateY(0) scale(1); }
  50% { transform: translateY(-20px) scale(1.03); }
}

.hero-badge {
  display: inline-flex; align-items: center; gap: 7px;
  background: white; border: 1px solid rgba(91,69,224,0.2);
  color: var(--purple); font-size: 12px; font-weight: 500;
  padding: 6px 16px; border-radius: var(--radius-pill);
  margin-bottom: 28px; letter-spacing: 0.03em;
  box-shadow: 0 2px 12px rgba(91,69,224,0.1);
  animation: fadeUp 0.5s ease both;
}
.badge-dot {
  width: 7px; height: 7px; border-radius: 50%;
  background: var(--teal);
  box-shadow: 0 0 0 3px rgba(13,158,117,0.2);
  animation: pulse 2s ease-in-out infinite;
}
@keyframes pulse {
  0%, 100% { box-shadow: 0 0 0 3px rgba(13,158,117,0.2); }
  50% { box-shadow: 0 0 0 6px rgba(13,158,117,0.08); }
}

.hero h1 {
  font-size: clamp(2.8rem, 7vw, 5rem);
  font-weight: 800; color: var(--ink);
  max-width: 700px; margin-bottom: 20px;
  animation: fadeUp 0.5s 0.1s ease both;
}
.hero h1 em {
  font-style: normal; color: var(--purple);
  position: relative;
}
.hero h1 em::after {
  content: '';
  position: absolute; bottom: -4px; left: 0; right: 0;
  height: 3px; background: var(--purple);
  border-radius: 2px; opacity: 0.3;
}
.hero-sub {
  font-size: 18px; color: var(--ink3);
  max-width: 460px; margin: 0 auto 40px;
  line-height: 1.6;
  animation: fadeUp 0.5s 0.2s ease both;
}

.search-box {
  width: 100%; max-width: 580px;
  background: white;
  border: 1.5px solid rgba(91,69,224,0.2);
  border-radius: var(--radius);
  display: flex; align-items: center;
  padding: 8px 8px 8px 20px;
  gap: 10px; margin-bottom: 18px;
  box-shadow: 0 4px 30px rgba(91,69,224,0.1);
  transition: border-color 0.2s, box-shadow 0.2s;
  animation: fadeUp 0.5s 0.3s ease both;
}
.search-box:focus-within {
  border-color: var(--purple);
  box-shadow: 0 4px 30px rgba(91,69,224,0.2);
}
.search-icon { color: var(--ink3); font-size: 20px; flex-shrink: 0; }
.search-box input {
  flex: 1; border: none; outline: none;
  font-family: 'DM Sans', sans-serif;
  font-size: 15px; color: var(--ink);
  background: transparent;
}
.search-box input::placeholder { color: var(--ink3); }
.search-btn {
  background: var(--purple); color: white;
  border: none; padding: 12px 24px;
  border-radius: 8px;
  font-family: 'Syne', sans-serif;
  font-size: 14px; font-weight: 600;
  cursor: pointer; white-space: nowrap;
  transition: background 0.15s, transform 0.1s;
  display: flex; align-items: center; gap: 6px;
}
.search-btn:hover { background: var(--purple-dark); transform: scale(1.02); }

.chips {
  display: flex; flex-wrap: wrap; gap: 8px; justify-content: center;
  animation: fadeUp 0.5s 0.4s ease both;
}
.chip {
  display: inline-flex; align-items: center; gap: 6px;
  background: white; border: 1px solid rgba(0,0,0,0.08);
  color: var(--ink2); font-size: 13px; font-weight: 500;
  padding: 7px 14px; border-radius: var(--radius-pill);
  cursor: pointer; transition: all 0.15s;
}
.chip:hover {
  background: var(--purple); color: white;
  border-color: var(--purple); transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(91,69,224,0.25);
}

@keyframes fadeUp {
  from { opacity: 0; transform: translateY(18px); }
  to { opacity: 1; transform: translateY(0); }
}

/* ── Stats ── */
.stats-bar {
  background: white;
  border-top: 1px solid rgba(0,0,0,0.06);
  border-bottom: 1px solid rgba(0,0,0,0.06);
  padding: 24px 40px;
  display: flex; align-items: center; justify-content: center; gap: 0;
}
.stat-item {
  flex: 1; text-align: center;
  padding: 0 24px;
  border-right: 1px solid rgba(0,0,0,0.08);
  max-width: 200px;
}
.stat-item:last-child { border-right: none; }
.stat-num {
  font-family: 'Syne', sans-serif;
  font-size: 28px; font-weight: 800; color: var(--purple);
}
.stat-lbl { font-size: 13px; color: var(--ink3); margin-top: 2px; }

/* ── Section ── */
.section { padding: 72px 40px; max-width: 1100px; margin: 0 auto; }
.section-header { margin-bottom: 40px; }
.section-tag {
  display: inline-flex; align-items: center; gap: 6px;
  background: var(--purple-light); color: var(--purple);
  font-size: 11px; font-weight: 600; letter-spacing: 0.08em;
  padding: 5px 12px; border-radius: var(--radius-pill);
  text-transform: uppercase; margin-bottom: 12px;
}
.section h2 {
  font-size: clamp(1.8rem, 4vw, 2.8rem);
  font-weight: 800; color: var(--ink);
}
.section-sub { font-size: 16px; color: var(--ink3); margin-top: 8px; max-width: 500px; }

/* ── Services grid ── */
.services-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
  gap: 14px;
}
.svc-card {
  background: white;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: var(--radius);
  padding: 24px 18px;
  cursor: pointer;
  transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  text-align: center;
}
.svc-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 12px 32px rgba(0,0,0,0.09);
  border-color: rgba(91,69,224,0.2);
}
.svc-icon {
  width: 52px; height: 52px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  margin: 0 auto 14px; font-size: 24px;
}
.svc-card h4 { font-family: 'Syne', sans-serif; font-size: 14px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
.svc-card p { font-size: 12px; color: var(--ink3); }

/* ── How it works ── */
.hiw-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; }
.hiw-card {
  background: white;
  border: 1px solid rgba(0,0,0,0.07);
  border-radius: var(--radius); padding: 28px 24px;
  position: relative; overflow: hidden;
}
.hiw-card::before {
  content: attr(data-num);
  position: absolute; top: -10px; right: 16px;
  font-family: 'Syne', sans-serif;
  font-size: 72px; font-weight: 800;
  color: rgba(91,69,224,0.06);
  line-height: 1;
}
.hiw-icon {
  width: 46px; height: 46px; border-radius: 12px;
  background: var(--purple-light);
  display: flex; align-items: center; justify-content: center;
  font-size: 22px; margin-bottom: 16px; color: var(--purple);
}
.hiw-card h3 { font-family: 'Syne', sans-serif; font-size: 17px; font-weight: 700; margin-bottom: 8px; }
.hiw-card p { font-size: 14px; color: var(--ink3); line-height: 1.6; }

/* ── Payment ── */
.pay-section {
  background: var(--ink);
  border-radius: 20px;
  padding: 52px 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
  align-items: center; margin: 0 40px;
}
.pay-section h2 {
  font-family: 'Syne', sans-serif;
  font-size: 2.2rem; font-weight: 800; color: white;
  margin-bottom: 12px;
}
.pay-section p { color: rgba(255,255,255,0.55); font-size: 15px; line-height: 1.6; }
.pay-methods { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
.pay-method {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.1);
  border-radius: var(--radius);
  padding: 16px 20px;
  display: flex; align-items: center; gap: 14px;
}
.pay-method-icon {
  width: 40px; height: 40px; border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex-shrink: 0;
}
.pay-method-info { flex: 1; }
.pay-method-info strong { display: block; color: white; font-size: 14px; font-weight: 500; }
.pay-method-info span { font-size: 12px; color: rgba(255,255,255,0.4); }
.pay-badge {
  font-size: 11px; font-weight: 600; padding: 3px 10px;
  border-radius: var(--radius-pill);
}
.badge-live { background: rgba(13,158,117,0.2); color: #4ecda4; }
.badge-soon { background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.35); }

/* ── Provider section ── */
.provider-section {
  background: linear-gradient(135deg, var(--purple) 0%, var(--purple-dark) 100%);
  border-radius: 20px;
  padding: 52px 48px;
  display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
  align-items: center; margin: 0 40px 72px;
}
.provider-section h2 { color: white; font-size: 2.2rem; font-weight: 800; margin-bottom: 12px; }
.provider-section p { color: rgba(255,255,255,0.7); font-size: 15px; line-height: 1.6; }
.perks { list-style: none; margin-top: 20px; display: flex; flex-direction: column; gap: 10px; }
.perks li {
  display: flex; align-items: center; gap: 10px;
  color: rgba(255,255,255,0.85); font-size: 14px;
}
.perk-dot { width: 8px; height: 8px; border-radius: 50%; background: #a8f0d8; flex-shrink: 0; }
.btn-white {
  background: white; color: var(--purple);
  border: none; padding: 14px 30px;
  border-radius: var(--radius-sm);
  font-family: 'Syne', sans-serif;
  font-size: 15px; font-weight: 700;
  cursor: pointer; transition: all 0.15s;
  display: inline-flex; align-items: center; gap: 8px;
}
.btn-white:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,0,0,0.15); }

/* ── Footer ── */
footer {
  background: var(--ink);
  color: rgba(255,255,255,0.5);
  text-align: center; padding: 32px 40px;
  font-size: 13px;
}
footer strong { color: rgba(255,255,255,0.8); font-family: 'Syne', sans-serif; }

/* ── Provider Signup Page ── */
.signup-page { max-width: 560px; margin: 60px auto; padding: 0 24px 80px; }
.signup-page h1 { font-size: 2.2rem; font-weight: 800; color: var(--ink); margin-bottom: 8px; }
.signup-page .sub { font-size: 15px; color: var(--ink3); margin-bottom: 36px; }
.form-group { margin-bottom: 18px; }
.form-group label {
  display: block; font-size: 13px; font-weight: 500;
  color: var(--ink2); margin-bottom: 6px;
}
.form-group input, .form-group select, .form-group textarea {
  width: 100%; padding: 13px 16px;
  border: 1.5px solid rgba(0,0,0,0.1);
  border-radius: var(--radius-sm);
  font-family: 'DM Sans', sans-serif;
  font-size: 15px; color: var(--ink);
  background: white; outline: none;
  transition: border-color 0.2s;
}
.form-group input:focus, .form-group select:focus, .form-group textarea:focus {
  border-color: var(--purple);
  box-shadow: 0 0 0 3px rgba(91,69,224,0.1);
}
.form-group textarea { resize: vertical; min-height: 90px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.service-checkboxes {
  display: grid; grid-template-columns: 1fr 1fr; gap: 8px;
}
.svc-check {
  display: flex; align-items: center; gap: 8px;
  padding: 10px 14px;
  border: 1.5px solid rgba(0,0,0,0.08);
  border-radius: var(--radius-sm); cursor: pointer;
  transition: all 0.15s; font-size: 14px; color: var(--ink2);
}
.svc-check input { width: auto; }
.svc-check:hover { border-color: var(--purple); background: var(--purple-light); }
.submit-btn {
  width: 100%; background: var(--purple); color: white;
  border: none; padding: 15px;
  border-radius: var(--radius-sm);
  font-family: 'Syne', sans-serif;
  font-size: 16px; font-weight: 700;
  cursor: pointer; margin-top: 8px;
  transition: background 0.15s, transform 0.1s;
}
.submit-btn:hover { background: var(--purple-dark); transform: translateY(-1px); }
.form-note { font-size: 12px; color: var(--ink3); text-align: center; margin-top: 12px; }

/* ── Success modal ── */
.modal-overlay {
  display: none; position: fixed; inset: 0;
  background: rgba(14,12,26,0.6);
  z-index: 200; align-items: center; justify-content: center;
}
.modal-overlay.open { display: flex; }
.modal {
  background: white; border-radius: var(--radius);
  padding: 40px 36px; max-width: 400px; width: 90%;
  text-align: center;
}
.modal-icon {
  width: 64px; height: 64px; border-radius: 50%;
  background: var(--teal-light);
  display: flex; align-items: center; justify-content: center;
  font-size: 28px; margin: 0 auto 20px;
}
.modal h3 { font-family: 'Syne', sans-serif; font-size: 1.4rem; font-weight: 800; margin-bottom: 8px; }
.modal p { font-size: 14px; color: var(--ink3); line-height: 1.6; }
.modal-btn {
  display: inline-block; margin-top: 24px;
  background: var(--purple); color: white;
  border: none; padding: 12px 28px;
  border-radius: var(--radius-sm);
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px;
  cursor: pointer;
}

/* ── Results panel ── */
.results-panel {
  display: none; max-width: 580px;
  margin: 20px auto 0;
  background: white; border: 1.5px solid rgba(91,69,224,0.2);
  border-radius: var(--radius); overflow: hidden;
  box-shadow: 0 8px 32px rgba(91,69,224,0.12);
  animation: fadeUp 0.3s ease both;
}
.results-panel.open { display: block; }
.results-header {
  background: var(--purple); padding: 14px 20px;
  display: flex; align-items: center; justify-content: space-between;
}
.results-header span { color: white; font-size: 13px; font-weight: 500; }
.results-close { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 20px; cursor: pointer; line-height: 1; }
.result-item {
  display: flex; align-items: center; gap: 14px;
  padding: 14px 20px; border-bottom: 1px solid rgba(0,0,0,0.05);
}
.result-item:last-child { border-bottom: none; }
.result-avatar {
  width: 42px; height: 42px; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: 'Syne', sans-serif; font-weight: 700; font-size: 14px;
  flex-shrink: 0;
}
.result-info { flex: 1; }
.result-info strong { display: block; font-size: 14px; color: var(--ink); }
.result-info span { font-size: 12px; color: var(--ink3); }
.result-eta {
  background: var(--teal-light); color: var(--teal);
  font-size: 12px; font-weight: 600; padding: 5px 12px;
  border-radius: var(--radius-pill);
}
.result-book {
  background: var(--purple); color: white;
  border: none; padding: 8px 16px;
  border-radius: var(--radius-sm);
  font-size: 13px; font-weight: 600; cursor: pointer;
}

/* ── Responsive ── */
@media (max-width: 768px) {
  nav { padding: 0 20px; }
  .nav-links { display: none; }
  .section { padding: 48px 20px; }
  .hiw-grid { grid-template-columns: 1fr; }
  .pay-section, .provider-section { grid-template-columns: 1fr; padding: 36px 28px; margin: 0 20px; }
  .stats-bar { padding: 20px; }
  .stat-item { padding: 0 12px; }
  .stat-num { font-size: 22px; }
}
</style>
</head>
<body>

<!-- NAV -->
<nav>
  <a class="nav-logo" onclick="showPage('home')">
    <div class="logo-mark">S</div>
    Solution
  </a>
  <div class="nav-links">
    <a onclick="showPage('home')">Home</a>
    <a onclick="scrollToSection('services')">Services</a>
    <a onclick="scrollToSection('how')">How it works</a>
    <a onclick="showPage('provider')">For providers</a>
  </div>
  <button class="nav-cta" onclick="showPage('provider')">Join as provider</button>
</nav>

<!-- ══════════════ HOME PAGE ══════════════ -->
<div id="page-home" class="page active">

  <!-- Hero -->
  <section class="hero">
    <div class="hero-orb hero-orb1"></div>
    <div class="hero-orb hero-orb2"></div>
    <div class="hero-badge">
      <div class="badge-dot"></div>
      Live — Agra & nearby areas
    </div>
    <h1>Just type your problem,<br>get a <em>solution</em></h1>
    <p class="hero-sub">Mechanic, plumber, electrician & more. One search, instant help at your doorstep.</p>

    <div class="search-box">
      <svg class="search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
      <input type="text" id="heroSearch" placeholder="e.g. My car won't start, I need help…" />
      <button class="search-btn" onclick="doSearch()">
        Find help
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
      </button>
    </div>

    <div id="resultsPanel" class="results-panel">
      <div class="results-header">
        <span id="resultsTitle">Finding providers near you…</span>
        <button class="results-close" onclick="document.getElementById('resultsPanel').classList.remove('open')">×</button>
      </div>
      <div id="resultsList"></div>
    </div>

    <div class="chips" style="margin-top:18px">
      <span class="chip" onclick="quickSearch('mechanic')">🔧 Mechanic</span>
      <span class="chip" onclick="quickSearch('plumber')">🪠 Plumber</span>
      <span class="chip" onclick="quickSearch('electrician')">⚡ Electrician</span>
      <span class="chip" onclick="quickSearch('pickup and drop')">🚗 Pickup & drop</span>
      <span class="chip" onclick="quickSearch('out of fuel')">⛽ Out of fuel</span>
      <span class="chip" onclick="quickSearch('carpenter')">🪚 Carpenter</span>
    </div>
  </section>

  <!-- Stats -->
