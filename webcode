<script>
function showPage(name) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.getElementById('page-' + name).classList.add('active');
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function scrollToSection(id) {
  showPage('home');
  setTimeout(() => {
    const el = document.getElementById(id);
    if (el) el.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }, 100);
}

const providers = {
  mechanic: [
    { name: 'Suresh Auto', area: 'Tajganj', rating: '4.8', eta: '12 min', color: '#f0eeff', text: '#5b45e0', init: 'SA' },
    { name: 'Ravi Motors', area: 'Sadar Bazaar', rating: '4.6', eta: '18 min', color: '#e0f5ee', text: '#0d9e75', init: 'RM' },
    { name: 'Quick Fix Garage', area: 'Civil Lines', rating: '4.9', eta: '22 min', color: '#fdeee9', text: '#e8401c', init: 'QF' },
  ],
  plumber: [
    { name: 'Deepak Plumbing', area: 'Sikandra', rating: '4.7', eta: '15 min', color: '#e0f5ee', text: '#0d9e75', init: 'DP' },
    { name: 'Water Works', area: 'Bodla', rating: '4.5', eta: '20 min', color: '#e5f0fb', text: '#1a6fc4', init: 'WW' },
  ],
  electrician: [
    { name: 'Bijli Bhai', area: 'Shahganj', rating: '4.9', eta: '10 min', color: '#fdf2e0', text: '#c97a10', init: 'BB' },
    { name: 'PowerFix', area: 'Dayalbagh', rating: '4.7', eta: '17 min', color: '#f0eeff', text: '#5b45e0', init: 'PF' },
  ],
  default: [
    { name: 'Solution Helper', area: 'Your area', rating: '4.8', eta: '15 min', color: '#f0eeff', text: '#5b45e0', init: 'SH' },
    { name: 'Quick Assist', area: 'Nearby', rating: '4.6', eta: '20 min', color: '#e0f5ee', text: '#0d9e75', init: 'QA' },
  ]
};

function doSearch() {
  const val = document.getElementById('heroSearch').value.trim();
  if (!val) return;
  showResults(val);
}

function quickSearch(service) {
  document.getElementById('heroSearch').value = 'I need a ' + service;
  showResults(service);
  document.getElementById('heroSearch').scrollIntoView({ behavior: 'smooth', block: 'center' });
}

function showResults(query) {
  const panel = document.getElementById('resultsPanel');
  const title = document.getElementById('resultsTitle');
  const list = document.getElementById('resultsList');

  const key = Object.keys(providers).find(k => query.toLowerCase().includes(k)) || 'default';
  const data = providers[key];

  title.textContent = 'Found ' + data.length + ' providers near you for "' + query + '"';
  list.innerHTML = data.map(p => `
    <div class="result-item">
      <div class="result-avatar" style="background:${p.color};color:${p.text}">${p.init}</div>
      <div class="result-info">
        <strong>${p.name}</strong>
        <span>${p.area} · ⭐ ${p.rating}</span>
      </div>
      <span class="result-eta">${p.eta}</span>
      <button class="result-book" onclick="alert('Booking confirmed! ${p.name} will arrive in ${p.eta}. Pay after work is done.')">Book</button>
    </div>
  `).join('');

  panel.classList.add('open');
}

document.getElementById('heroSearch').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') doSearch();
});

function submitProvider(e) {
  e.preventDefault();
  document.getElementById('successModal').classList.add('open');
}

function closeModal() {
  document.getElementById('successModal').classList.remove('open');
  showPage('home');
}
</script>
